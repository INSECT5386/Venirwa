{
  "문법": {
    "어순": {
      "일반문 [주어 수식 + 주어] [목적어 수식 + 목적어] [부사어 + 동사] [기타 부사구]": {
        "mapli en benlipati xemles mape atzli haliospoxlitn coberxemlebot": "평범한 나는 특별한 돼지를 끔찍  죽일 것이다 세계의 왼쪽에서 톱으로",
        "it se chorkirbarli.": "사람은 이다 생각하는 동물",
        "it kiores ti mitn.": "나는 그것을 줄 것이다 너에게",
        "it calbs 13 kiliqe.": "나는 놀 것이다 13시에"
      },
      "복합문 [주어 수식 + 주어] [부사어 + 동사] [배경 정보] nu [하위 문장]": {
        "maple en ptros haliospoxlitn nu petrun xemlebo kior titn.": "평범한 나는 보았다 세상의 왼쪽에서 (nu 이하를) 뚱뚱한 사람이 무기를 주다 그에게"
      },
      "목적문 [주어 수식 + 주어] [목적어 수식1 + 목적어1] [부사어1 + 동사1] no [목적어 수식2 + 목적어2] [부사어2 + 동사2]": {
        "benlipati ti stueti xenanpalzobr no clerakli xuares.": "끔찍한 그는 멍청한 그것을 잔인  때리다 (위해) 귀여운 고양이를 죽일 것이다."
      },
      "명령문 ([주어 수식 + 주어]) [목적어 수식 목적어] [부사어 + 동사]pi [기타 부사구]": {
        "stuermi petrum petrpi pencuntn.": "멍청한 너는 뚱뚱한 사람을 도와라. 학교에서",
        "stermi ptrpi paxlistantn nu benli it benlihako hake.": "똑똑한 너는 보아라. 남극에서 (nu 이하를) 미친 사람이 미친 물을 마시는 것을",
        "mi xirpi xirmat no xemxumseti xor.": "너는 이동해라 자동차로 (위해) 폭파범인 그를 체포하기 위해",
        "mi bentaleschotpe, xananpinpi.": "너는 기절할 생각으로 일해라.",
        "mi kelspi barimtn 13 kilipe.": "너는 와라 집으로 13시까지.",
        "mi ti tekpi 13 kiliqe.": "너는 그것을 시작해라 13시부터"
      },
      "이유/피동문 [대상 수식 + 대상] len, [주어 수식 + 주어] [부사어 + 동사] [기타 부사구]": {
        "stuerti len, cenbalumz cenbalweros barimtn.": "멍청한 그 때문에, 많은 사람들이 많이 다쳤다 집에서",
        "en se it len, en xir zameltotn.": "나는 이다 사람 때문에, 나는 간다 학교에"
      }
    },
    "의문법": {
      "무엇": {
        "1": "[주제]nt hea? ([주제]는 무엇인가?)",
        "2": "hea? (뭐야?)"
      },
      "왜": {
        "1": "[문장]nt xea? (왜 [문장]입니까?)",
        "2": "xea? (왜?)",
        "3": "buartn chornt mea? (죽음에 대해 어떻게 생각하나요?)"
      },
      "어떻게": {
        "1": "[문장]nt mea? ([문장]을 어떻게 합니까?)",
        "2": "sca mea (어떡해)"
      }
    }
